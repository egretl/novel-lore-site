---
import { getCollection } from "astro:content";
import ListingPage from "../components/ListingPage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { findSection } from "../lib/sections";

const section = findSection("factions")!;
const entries = await getCollection("factions");
---

<BaseLayout title={section.title}>
  <ListingPage section={section} entries={entries} />
</BaseLayout>

