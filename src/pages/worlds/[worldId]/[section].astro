---
import { getCollection } from "astro:content";
import { GraphCanvas } from "../../../components/GraphCanvas";
import ListingPage from "../../../components/ListingPage.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { buildGraph } from "../../../lib/graph";
import { contentSections, sections } from "../../../lib/sections";
import { filterByWorld, filterRelationsByWorld, sortWorlds } from "../../../lib/worlds";
import type { CollectionKey } from "astro:content";
import type { LoreEntry } from "../../../lib/schemas";

const contentCollectionKeys = contentSections.map((section) => section.key);

export async function getStaticPaths() {
  const worlds = sortWorlds((await getCollection("worlds")).map((world) => world.data));

  return worlds.flatMap((world) =>
    sections.map((section) => ({
      params: { worldId: world.id, section: section.key },
      props: { world, section },
    })),
  );
}

const { world, section } = Astro.props;
const isGraph = section.key === "graph";

const entries = isGraph
  ? []
  : (await getCollection(section.key as CollectionKey)).filter((entry) => entry.data.worldId === world.id);

const graph = isGraph
  ? buildGraph(
      (
        await Promise.all(
          contentCollectionKeys.map(async (collection) =>
            filterByWorld(
              (await getCollection(collection as CollectionKey)).map((entry) => ({
                ...entry.data,
                collection,
              })),
              world.id,
            ),
          ),
        )
      ).flat() as LoreEntry[],
      filterRelationsByWorld(
        (await getCollection("relations")).map((entry) => entry.data),
        world.id,
      ),
    )
  : null;
---

<BaseLayout title={`${world.title} - ${section.title}`} worldId={world.id}>
  {
    isGraph && graph ? (
      <>
        <section class="page-heading">
          <p>{world.title}</p>
          <h1>{section.title}</h1>
          <span>{section.description}</span>
        </section>
        <GraphCanvas graph={graph} client:load />
      </>
    ) : (
      <ListingPage section={section} entries={entries} />
    )
  }
</BaseLayout>
